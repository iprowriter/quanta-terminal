# LLM providers 
GOOGLE_API_KEY=google-ai-api-key
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434

# LangSmith (tracing + observability)
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=langsmith-api-key
LANGSMITH_TRACING=true
LANGCHAIN_PROJECT=quanta-terminal

# Pinecone (vector store)
PINECONE_API_KEY=pine-cone-api-key
PINECONE_INDEX_NAME=quanta-terminal
PINECONE_INDEX_DIMENSION=1536
PINECONE_INDEX_METRIC=cosine

# News
NEWS_API_KEY=newsapi-key             # https://newsapi.org — free tier

# Redis (caching + Celery broker)
REDIS_URL=redis://localhost:6379/0

# Supabase (postgres + auth)
SUPABASE_URL=https://my-url.supabase.co
SUPABASE_ANON_KEY=eyJ...            # Settings > API > anon/public
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # Settings > API > service_role (keep secret!)
SUPABASE_JWT_SECRET=your-jwt-secret # Settings > API > JWT Secret (used to verify magic-link tokens)
SUPABASE_DIRECT_URL=postgresql://postgres:password.@db.my-url.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password.@db.my-url.supabase.co:5432/postgres

# App
APP_ENV=development
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:3000   # production: https://your-app.vercel.app

# Sentry (optional — leave blank to disable)
SENTRY_DSN=https://...@sentry.io/...

# Stocks to track (comma-separated)
TRACKED_TICKERS=QUBT,RGTI,QBTS,IONQ,NVDA,SMCI,MSTR,ARQQ,IBMQ,INTC

